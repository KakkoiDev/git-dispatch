#!/bin/bash
# git-dispatch commit-msg hook: enforces Dispatch-Target-Id trailer on every commit
# Install with: git dispatch init

msg_file="$1"

# Skip merge commits
if git rev-parse MERGE_HEAD &>/dev/null; then
    exit 0
fi

if ! grep -q "^Dispatch-Target-Id:" "$msg_file"; then
    echo "Error: Missing Dispatch-Target-Id trailer."
    echo "Use: git commit --trailer 'Dispatch-Target-Id=N'"
    exit 1
fi

# Reject duplicate Dispatch-Target-Id trailers
target_count=$(grep -c "^Dispatch-Target-Id:" "$msg_file")
if [[ "$target_count" -gt 1 ]]; then
    echo "Error: Multiple Dispatch-Target-Id trailers found ($target_count). Only one is allowed per commit."
    exit 1
fi

# Reject duplicate Dispatch-Source-Keep trailers
source_keep_count=$(grep -c "^Dispatch-Source-Keep:" "$msg_file" || true)
if [[ "$source_keep_count" -gt 1 ]]; then
    echo "Error: Multiple Dispatch-Source-Keep trailers found ($source_keep_count). Only one is allowed per commit."
    exit 1
fi

# Validate Dispatch-Target-Id is numeric (integer or decimal) or "all"
target_id=$(grep "^Dispatch-Target-Id:" "$msg_file" | head -1 | sed 's/^Dispatch-Target-Id:[[:space:]]*//')
if [[ "$target_id" == "all" ]]; then
    exit 0
fi
if ! echo "$target_id" | grep -Eq '^[1-9][0-9]*(\.[0-9]+)?$'; then
    if echo "$target_id" | grep -Eq '^0[0-9]'; then
        echo "Error: Dispatch-Target-Id '$target_id' has a leading zero. Use '${target_id#0}' instead."
    elif [[ "$target_id" == "0" ]]; then
        echo "Error: Dispatch-Target-Id '0' is not valid. Use a positive integer."
    else
        echo "Error: Dispatch-Target-Id '$target_id' is not numeric. Use integer or decimal (e.g., 1, 2, 1.5) or 'all'."
    fi
    exit 1
fi
