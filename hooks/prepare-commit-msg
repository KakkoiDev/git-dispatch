#!/bin/bash
# git-dispatch prepare-commit-msg hook: auto-carry Dispatch-Target-Id from previous commit
# Install with: git dispatch init

msg_file="$1"
source="$2"  # message, template, merge, squash, commit

# Skip merge and amend
[[ "$source" == "merge" || "$source" == "commit" ]] && exit 0

# Skip auto-carry on checkout branches (interleaved targets make it unreliable)
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
[[ "$current_branch" == dispatch-checkout/* ]] && exit 0

# Skip if Dispatch-Target-Id already present
grep -q "^Dispatch-Target-Id:" "$msg_file" && exit 0

# Read previous commit's Dispatch-Target-Id
prev_target=$(git log -1 --format="%(trailers:key=Dispatch-Target-Id,valueonly)" HEAD 2>/dev/null | tr -d '[:space:]')
[[ -z "$prev_target" ]] && exit 0

# Add Dispatch-Target-Id trailer
git interpret-trailers --in-place --trailer "Dispatch-Target-Id=$prev_target" "$msg_file"

exit 0
