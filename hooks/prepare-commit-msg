#!/bin/bash
# git-dispatch prepare-commit-msg hook: auto-carry Target-Id from previous commit
# Install with: git dispatch init

msg_file="$1"
source="$2"  # message, template, merge, squash, commit

# Skip merge and amend
[[ "$source" == "merge" || "$source" == "commit" ]] && exit 0

# Skip if Target-Id already present
grep -q "^Target-Id:" "$msg_file" && exit 0

# Read previous commit's Target-Id
prev_target=$(git log -1 --format="%(trailers:key=Target-Id,valueonly)" HEAD 2>/dev/null | tr -d '[:space:]')
[[ -z "$prev_target" ]] && exit 0

# Add Target-Id trailer
git interpret-trailers --in-place --trailer "Target-Id=$prev_target" "$msg_file"

exit 0
